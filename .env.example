# Example environment configuration for the IBGE enrichment project

# URL of the Edge Function that receives the stats JSON
PROJECT_FUNCTION_URL=

# Access token used to authenticate against the Edge Function
ACCESS_TOKEN=

# Optional override for the IBGE municipalities base URL
# If not set, the client will use
# https://servicodados.ibge.gov.br/api/v1/localidades/municipios
IBGE_BASE_URL=
